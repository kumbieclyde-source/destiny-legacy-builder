{
  "name": "destiny-legacy-builder",
  "version": "1.0.0",
  "description": "A high-ticket $5,000 offer landing page for the DESTINY Legacy Builder program",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.1",
    "jose": "6.1.0",
    "lucide-react": "^0.408.0",
    "mysql2": "^3.15.0",
    "react": "^19.0.0-rc-66f6ca18-20240904",
    "react-dom": "^19.0.0-rc-66f6ca18-20240904",
    "react-router-dom": "^6.30.3",
    "streamdown": "^2.5.0",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/react": "^19.0.0-rc.0",
    "@types/react-dom": "^19.0.0-rc.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.21.4",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vite": "^7.1.9",
    "vitest": "^1.0.4"
  }
